# Copy to .env and fill in the providers you want to use.
# Nuxt maps NUXT_* automatically onto runtimeConfig.

# OpenAI (chat and/or embeddings)
NUXT_OPENAI_API_KEY=

# Anthropic (chat only — Anthropic has no embeddings API)
NUXT_ANTHROPIC_API_KEY=

# LM Studio local OpenAI-compatible server (chat and/or embeddings)
NUXT_LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Where uploaded PDFs, generated markdown and the SQLite db live
NUXT_DATA_DIR=./data
